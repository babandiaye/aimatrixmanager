// Prisma schema — aimatrixmanager
// Postgres 15 + pgvector. Vector dim = 1536 (OpenAI text-embedding-3-small / Voyage large).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  ENSEIGNANT
  AUDITOR
}

enum AgentStatus {
  ENABLED
  DISABLED
  SUSPENDED
}

enum LLMProvider {
  ANTHROPIC
  OLLAMA
}

// Origine d'un salon Matrix :
//  - MATRIX : créé nativement (Element, formation1-chat.unchk.sn, autre client)
//  - MOODLE : provisionné via le plugin mod_matrix d'un cours Moodle
enum RoomSource {
  MATRIX
  MOODLE
}

// Événements d'authentification — pour audit & forensic.
enum AuthEventType {
  SIGN_IN
  SIGN_OUT
}

// ─── Settings système (singleton, id="global") ───────────────────────────────

model SystemSettings {
  id          String   @id @default("global")
  updatedAt   DateTime @updatedAt
  updatedById String?
}

// ─── Auth / Admin users ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?   // null si l'utilisateur ne se connecte qu'en OIDC
  role          UserRole  @default(AUDITOR)

  // Pour le rôle ENSEIGNANT : mapping résolu plateforme → moodleUserId
  // (par email, via core_user_get_users_by_field). Format JSON :
  //   { "<platformId>": <moodleUserId>, ... }
  // Mis à jour quand resolveTeacherCourses() est appelé. TTL = 1h.
  moodleUserMap     Json?
  lastMoodleSyncAt  DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  createdAgents       Agent[]      @relation("AgentCreator")
  createdAssignments  RoomAgent[]  @relation("AssignmentCreator")
  authAuditLogs       AuthAuditLog[]
}

// Tables Auth.js / NextAuth — schéma standard requis par @auth/prisma-adapter
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Audit auth (sign-in / sign-out) ─────────────────────────────────────────
// Forensic des connexions — distinct d'AuditLog (qui trace les conversations
// agent ↔ étudiant). On garde l'email même si le User est supprimé (SetNull).

model AuthAuditLog {
  id        String        @id @default(cuid())
  type      AuthEventType
  userId    String?
  user      User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String?       // capturé au moment de l'événement
  provider  String?       // "credentials" | "keycloak"
  createdAt DateTime      @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ─── Agent IA ─────────────────────────────────────────────────────────────────

model Agent {
  id          String      @id @default(cuid())
  // Identifiant Matrix
  slug        String      @unique // utilisé dans la mention @<slug>, ex. "kocc-barma"
  name        String      // display name
  description String?
  matrixUserId      String   @unique // "@kocc-barma:formation1-matrix.unchk.sn"
  matrixDeviceId    String?
  matrixAccessToken String?  // sensible — à chiffrer au repos en prod
  avatarUrl         String?

  // Config LLM
  provider     LLMProvider @default(ANTHROPIC)
  systemPrompt String      @db.Text
  model        String      @default("claude-sonnet-4-6")
  maxTokens    Int         @default(2048)
  temperature  Float?

  status     AgentStatus @default(DISABLED)
  // Heartbeat : le bot Python met à jour ce champ toutes les 30s
  lastHeartbeatAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  createdById String?
  createdBy   User?    @relation("AgentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  assignments      RoomAgent[]
  auditLogs        AuditLog[]
  crossSigning     AgentCrossSigning?

  @@index([status])
}

// ─── Cross-signing E2EE par agent ─────────────────────────────────────────────
// Une ligne par agent une fois le cross-signing initialisé. La master key
// signe SSK + USK ; SSK signe les devices. On garde sskPriv (chiffré) pour
// re-signer le device en cas de rotation (rotateAgentToken). On NE garde PAS
// masterPriv ni uskPriv (besoin one-shot) — réduction de surface.
//
// deviceSignedAt est null tant que le device n'a pas encore été signé par SSK
// (cas typique : à la création d'un agent, le bot Python n'a pas encore
// uploadé ses keys via /keys/upload — la signature device se fait dans un
// second temps via signAgentDevice()).

model AgentCrossSigning {
  agentId        String   @id
  agent          Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  masterPubKey   String   // base64 unpadded, 32 bytes Ed25519 — visible publiquement
  sskPubKey      String   // base64 unpadded
  uskPubKey      String   // base64 unpadded
  sskPrivEnc     String   @db.Text // AES-256-GCM enc:v1: pour re-signer un device
  signedDeviceId String?            // device_id qui a été signé par SSK
  deviceSignedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Plateformes Moodle (référentiel) ─────────────────────────────────────────
// Chaque plateforme = une instance Moodle (DISI, P11STN, ...) avec ses creds Web Services.

model MoodlePlatform {
  id          String   @id @default(cuid())
  key         String   @unique   // "DISI", "P11STN" — identifiant court réutilisable
  name        String              // "Moodle DISI"
  baseUrl     String              // "https://moodle.disi.unchk.sn" (sans / final)
  wsToken     String   @db.Text   // token Moodle Web Services
  wsUsername  String?             // login du compte service côté Moodle (optionnel)
  enabled     Boolean  @default(true)
  lastSyncedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  courses           MoodleCourse[]
  matrixActivities  MoodleMatrixActivity[]

  @@index([enabled])
}

// ─── Activités mod_matrix découvertes côté Moodle ─────────────────────────────
// Chaque ligne = une instance du plugin mod_matrix dans un cours Moodle.
// Source : WS mod_matrix_get_matrices_by_courses (Moodle plugin Famedly).

model MoodleMatrixActivity {
  id              String   @id @default(cuid())
  platformId      String
  platform        MoodlePlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  moodleId        Int      // id de l'instance mod_matrix côté Moodle
  courseModuleId  Int      // cmid — pour deep-link `/mod/matrix/view.php?id=<cmid>`
  moodleCourseId  Int      // course id Moodle (pour join avec MoodleCourse.moodleId)
  courseShortname String
  courseFullname  String
  name            String   // nom de l'activité (visible dans Moodle)
  topic           String?
  target          String?  // ex: "element-url"
  section         Int?
  // Tableau des rooms (1 par groupe Moodle) — `[{matrix_room_id, group_id, timecreated}]`
  // Conservé en JSON pour éviter la table 1-N tant qu'on n'en a pas l'usage.
  rooms           Json
  timecreated     DateTime
  timemodified    DateTime?
  lastSyncedAt    DateTime @default(now())

  @@unique([platformId, moodleId])
  @@index([platformId])
  @@index([platformId, moodleCourseId])
}

// ─── Cours Moodle (synchronisés) ──────────────────────────────────────────────

model MoodleCourse {
  id           String   @id @default(cuid())
  platformId   String
  platform     MoodlePlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  moodleId     Int      // course id côté Moodle
  shortname    String
  fullname     String
  lastSyncedAt DateTime?

  // RAG opt-in : si false (défaut), le cours n'est pas indexé même si présent
  // dans la table — économie de stockage et de calcul d'embeddings. À activer
  // sur les cours qui ont effectivement un agent Matrix affecté.
  reindexEnabled Boolean   @default(false)
  lastIndexedAt  DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  rooms     Room[]
  sections  MoodleSection[]
  resources MoodleResource[]
  chunks    MoodleResourceChunk[] @relation("CourseChunks")

  @@unique([platformId, moodleId])
  @@index([platformId])
}

// ─── Salons Matrix découverts ─────────────────────────────────────────────────

model Room {
  id            String   @id @default(cuid())
  matrixRoomId  String   @unique // "!abc:server"
  name          String?
  topic         String?
  isDirect      Boolean  @default(false) // DM si <= 2 membres
  isEncrypted   Boolean  @default(false)
  // Origine : MATRIX par défaut. Passe à MOODLE quand le sync mod_matrix
  // détecte que ce matrix_room_id provient d'une activité du plugin Moodle.
  source        RoomSource @default(MATRIX)

  moodleCourseId String?
  moodleCourse   MoodleCourse? @relation(fields: [moodleCourseId], references: [id], onDelete: SetNull)

  discoveredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments RoomAgent[]
  auditLogs   AuditLog[]

  @@index([moodleCourseId])
}

// ─── Affectation room ↔ agent ─────────────────────────────────────────────────

model RoomAgent {
  id      String  @id @default(cuid())
  roomId  String
  agentId String
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  enabled Boolean @default(true)

  assignedById String?
  assignedBy   User?    @relation("AssignmentCreator", fields: [assignedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([roomId, agentId])
  @@index([agentId])
}

// ─── Audit conversations ──────────────────────────────────────────────────────

model AuditLog {
  id      String @id @default(cuid())
  roomId  String
  agentId String
  room    Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  matrixEventId String? @unique // pour dédup
  senderMxid    String          // "@etudiant:server"
  userMessage   String  @db.Text
  agentResponse String? @db.Text

  // Coût / observabilité
  inputTokens      Int?
  outputTokens     Int?
  cacheReadTokens  Int?
  cacheWriteTokens Int?
  latencyMs        Int?
  error            String?

  createdAt DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([agentId, createdAt])
  @@index([senderMxid])
}

// ─── RAG : index pédagogique des cours Moodle ─────────────────────────────────
// Architecture en 3 niveaux :
//   MoodleSection  → MoodleResource  → MoodleResourceChunk
//
// Un chunk pointe SOIT vers une resource (PDF, page, book…), SOIT vers un
// summary de section (FK polymorphe : exactly one of resourceId/sectionId).
// On dénormalise courseId sur le chunk pour scoper le vector search au bon
// cours sans join (clé pour la perf à 10M+ chunks).
//
// L'embedding est nomic-embed-text (768-dim) servi par fromager.unchk.sn.
// Index HNSW pour la similarité cosine ajouté manuellement post-push (Prisma
// ne gère pas les index pgvector via le DSL).

model MoodleSection {
  id              String   @id @default(cuid())
  platformId      String
  courseId        String
  course          MoodleCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moodleId        Int      // section.id côté Moodle
  name            String
  summary         String?  @db.Text  // HTML brut de la section
  extractedText   String?  @db.Text  // HTML strippé pour chunking
  sectionnum      Int
  textExtractedAt DateTime?
  embeddedAt      DateTime?
  lastSyncedAt    DateTime @default(now())

  resources MoodleResource[]
  chunks    MoodleResourceChunk[]

  @@unique([courseId, moodleId])
  @@index([platformId])
}

model MoodleResource {
  id           String   @id @default(cuid())
  platformId   String
  courseId     String
  course       MoodleCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sectionId    String
  section      MoodleSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  cmid         Int      // course module id (unique côté Moodle)
  modname      String   // "resource", "page", "book", "label", "folder", ...
  name         String
  url          String?  // URL Moodle UI pour link to source
  description  String?  @db.Text  // HTML brut — c'est LE contenu pour modname=label, intro pour les autres

  // Pour les fichiers (modname=resource/folder)
  filename     String?
  mimetype     String?
  filesize     Int?
  contenthash  String?  // sha1 du fichier — clé de dédup
  fileurl      String?  // URL WS (à compléter avec ?token= au moment du download)

  // Liste complète des fichiers du module (pour book/folder qui en ont plusieurs).
  // Stocké en JSON: [{fileurl, filename, mimetype, filesize, contenthash?}, ...].
  // Si null/absent, on retombe sur fileurl seul (modules à fichier unique).
  files        Json?

  // Texte extrait — vide tant que pas indexé / si type non supporté
  extractedText String? @db.Text

  textExtractedAt  DateTime?
  embeddedAt       DateTime?
  lastSyncedAt     DateTime @default(now())
  syncError        String?  // dernier message d'erreur (pour debug UI)

  chunks MoodleResourceChunk[]

  @@unique([platformId, cmid])
  @@index([courseId])
  @@index([contenthash])
}

model MoodleResourceChunk {
  id         String @id @default(cuid())

  // Dénormalisé pour scoper le vector search par cours sans join
  courseId   String
  course     MoodleCourse @relation("CourseChunks", fields: [courseId], references: [id], onDelete: Cascade)

  // FK polymorphe : exactement un des deux est non-null
  resourceId String?
  resource   MoodleResource? @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  sectionId  String?
  section    MoodleSection?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  ordinal    Int
  text       String @db.Text
  tokenCount Int?

  embedding  Unsupported("vector(768)")?

  @@index([courseId])
  @@index([resourceId, ordinal])
  @@index([sectionId, ordinal])
}
